<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Pattern Lock Practice</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: #111;
      font-family: sans-serif;
      color: #fff;
      padding: 2rem;
    }
    h1 { font-size: 20px; font-weight: 500; margin-bottom: 1.5rem; color: #ccc; }
    .stats {
      display: flex;
      gap: 2rem;
      margin-bottom: 1.5rem;
    }
    .stat { text-align: center; }
    .stat-label { font-size: 12px; color: #888; margin-bottom: 4px; }
    .stat-value { font-size: 26px; font-weight: 500; color: #fff; }
    .stat-value.small { font-size: 13px; letter-spacing: 1px; min-height: 22px; }
    #status { font-size: 14px; color: #888; min-height: 20px; margin-bottom: 1rem; }
    svg { touch-action: none; user-select: none; }
    button {
      margin-top: 1.2rem;
      padding: 8px 24px;
      border-radius: 8px;
      border: 1px solid #444;
      background: transparent;
      color: #ccc;
      font-size: 13px;
      cursor: pointer;
      transition: background 0.15s;
    }
    button:hover { background: #222; }
    .hint { font-size: 12px; color: #555; margin-top: 1rem; text-align: center; max-width: 260px; }
  </style>
</head>
<body>
  <h1>Pattern Lock Practice</h1>

  <div class="stats">
    <div class="stat">
      <div class="stat-label">Attempts</div>
      <div class="stat-value" id="attempts">0</div>
    </div>
    <div class="stat">
      <div class="stat-label">Last Pattern</div>
      <div class="stat-value small" id="last-pattern">—</div>
    </div>
  </div>

  <div id="status">Draw your pattern</div>

  <svg id="grid" width="280" height="280" viewBox="0 0 280 280">
    <g id="lines-group"></g>
    <g id="active-line-group"></g>

    <!-- Row 0 -->
    <circle class="dot" cx="60" cy="60" r="22" fill="#1e1e1e" stroke="#444" stroke-width="1.5" data-id="1"/>
    <circle cx="60" cy="60" r="6" fill="#666" pointer-events="none" data-inner="1"/>
    <circle class="dot" cx="140" cy="60" r="22" fill="#1e1e1e" stroke="#444" stroke-width="1.5" data-id="2"/>
    <circle cx="140" cy="60" r="6" fill="#666" pointer-events="none" data-inner="2"/>
    <circle class="dot" cx="220" cy="60" r="22" fill="#1e1e1e" stroke="#444" stroke-width="1.5" data-id="3"/>
    <circle cx="220" cy="60" r="6" fill="#666" pointer-events="none" data-inner="3"/>
    <!-- Row 1 -->
    <circle class="dot" cx="60" cy="140" r="22" fill="#1e1e1e" stroke="#444" stroke-width="1.5" data-id="4"/>
    <circle cx="60" cy="140" r="6" fill="#666" pointer-events="none" data-inner="4"/>
    <circle class="dot" cx="140" cy="140" r="22" fill="#1e1e1e" stroke="#444" stroke-width="1.5" data-id="5"/>
    <circle cx="140" cy="140" r="6" fill="#666" pointer-events="none" data-inner="5"/>
    <circle class="dot" cx="220" cy="140" r="22" fill="#1e1e1e" stroke="#444" stroke-width="1.5" data-id="6"/>
    <circle cx="220" cy="140" r="6" fill="#666" pointer-events="none" data-inner="6"/>
    <!-- Row 2 -->
    <circle class="dot" cx="60" cy="220" r="22" fill="#1e1e1e" stroke="#444" stroke-width="1.5" data-id="7"/>
    <circle cx="60" cy="220" r="6" fill="#666" pointer-events="none" data-inner="7"/>
    <circle class="dot" cx="140" cy="220" r="22" fill="#1e1e1e" stroke="#444" stroke-width="1.5" data-id="8"/>
    <circle cx="140" cy="220" r="6" fill="#666" pointer-events="none" data-inner="8"/>
    <circle class="dot" cx="220" cy="220" r="22" fill="#1e1e1e" stroke="#444" stroke-width="1.5" data-id="9"/>
    <circle cx="220" cy="220" r="6" fill="#666" pointer-events="none" data-inner="9"/>
  </svg>

  <button id="reset-btn">Reset</button>
  <p class="hint">Drag across dots to draw your pattern. Release to finish.</p>

  <script>
    const dotPositions = {
      1:{x:60,y:60}, 2:{x:140,y:60}, 3:{x:220,y:60},
      4:{x:60,y:140}, 5:{x:140,y:140}, 6:{x:220,y:140},
      7:{x:60,y:220}, 8:{x:140,y:220}, 9:{x:220,y:220}
    };

    const svg = document.getElementById('grid');
    const linesGroup = document.getElementById('lines-group');
    const activeLineGroup = document.getElementById('active-line-group');
    const attemptsEl = document.getElementById('attempts');
    const lastPatternEl = document.getElementById('last-pattern');
    const statusEl = document.getElementById('status');

    let drawing = false, sequence = [], attempts = 0;

    function getSvgPoint(e) {
      const rect = svg.getBoundingClientRect();
      const clientX = e.touches ? e.touches[0].clientX : e.clientX;
      const clientY = e.touches ? e.touches[0].clientY : e.clientY;
      return {
        x: (clientX - rect.left) * (280 / rect.width),
        y: (clientY - rect.top) * (280 / rect.height)
      };
    }

    function getDotAt(pt) {
      for (const [id, pos] of Object.entries(dotPositions)) {
        const dx = pt.x - pos.x, dy = pt.y - pos.y;
        if (Math.sqrt(dx*dx + dy*dy) < 26) return parseInt(id);
      }
      return null;
    }

    function highlightDot(id, active) {
      const dot = svg.querySelector(`circle[data-id="${id}"]`);
      const inner = svg.querySelector(`circle[data-inner="${id}"]`);
      if (active) {
        dot.setAttribute('fill', '#1a3a5c');
        dot.setAttribute('stroke', '#378ADD');
        inner.setAttribute('fill', '#7ab8f5');
      } else {
        dot.setAttribute('fill', '#1e1e1e');
        dot.setAttribute('stroke', '#444');
        inner.setAttribute('fill', '#666');
      }
    }

    function addLine(fromId, toId) {
      const from = dotPositions[fromId], to = dotPositions[toId];
      const line = document.createElementNS('http://www.w3.org/2000/svg','line');
      line.setAttribute('x1', from.x); line.setAttribute('y1', from.y);
      line.setAttribute('x2', to.x); line.setAttribute('y2', to.y);
      line.setAttribute('stroke', '#378ADD');
      line.setAttribute('stroke-width', '3');
      line.setAttribute('stroke-linecap', 'round');
      linesGroup.appendChild(line);
    }

    function setActiveLine(fromId, toX, toY) {
      activeLineGroup.innerHTML = '';
      if (fromId === null) return;
      const from = dotPositions[fromId];
      const line = document.createElementNS('http://www.w3.org/2000/svg','line');
      line.setAttribute('x1', from.x); line.setAttribute('y1', from.y);
      line.setAttribute('x2', toX); line.setAttribute('y2', toY);
      line.setAttribute('stroke', '#378ADD');
      line.setAttribute('stroke-width', '2');
      line.setAttribute('stroke-dasharray', '5,4');
      line.setAttribute('stroke-linecap', 'round');
      activeLineGroup.appendChild(line);
    }

    function startDraw(e) {
      e.preventDefault();
      const pt = getSvgPoint(e);
      const dotId = getDotAt(pt);
      if (!dotId) return;
      drawing = true;
      sequence = [dotId];
      linesGroup.innerHTML = '';
      activeLineGroup.innerHTML = '';
      for (let i=1;i<=9;i++) highlightDot(i, false);
      highlightDot(dotId, true);
      statusEl.textContent = 'Drawing...';
      statusEl.style.color = '#5a9fd4';
    }

    function moveDraw(e) {
      if (!drawing) return;
      e.preventDefault();
      const pt = getSvgPoint(e);
      const dotId = getDotAt(pt);
      if (dotId && !sequence.includes(dotId)) {
        addLine(sequence[sequence.length-1], dotId);
        sequence.push(dotId);
        highlightDot(dotId, true);
        setActiveLine(null, 0, 0);
      } else {
        setActiveLine(sequence[sequence.length-1], pt.x, pt.y);
      }
    }

    function endDraw(e) {
      if (!drawing) return;
      drawing = false;
      activeLineGroup.innerHTML = '';
      if (sequence.length >= 2) {
        attempts++;
        attemptsEl.textContent = attempts;
        lastPatternEl.textContent = sequence.join(' → ');
        statusEl.textContent = 'Pattern recorded!';
        statusEl.style.color = '#4caf50';
      } else {
        statusEl.textContent = 'Too short — connect at least 2 dots';
        statusEl.style.color = '#e57373';
        linesGroup.innerHTML = '';
        sequence.forEach(id => highlightDot(id, false));
      }
    }

    svg.addEventListener('mousedown', startDraw);
    svg.addEventListener('mousemove', moveDraw);
    svg.addEventListener('mouseup', endDraw);
    svg.addEventListener('mouseleave', e => { if (drawing) endDraw(e); });
    svg.addEventListener('touchstart', startDraw, {passive:false});
    svg.addEventListener('touchmove', moveDraw, {passive:false});
    svg.addEventListener('touchend', endDraw);

    document.getElementById('reset-btn').addEventListener('click', () => {
      linesGroup.innerHTML = '';
      activeLineGroup.innerHTML = '';
      sequence = [];
      drawing = false;
      for (let i=1;i<=9;i++) highlightDot(i, false);
      statusEl.textContent = 'Draw your pattern';
      statusEl.style.color = '#888';
      lastPatternEl.textContent = '—';
    });
  </script>
</body>
</html>
